    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "msw": "^2.3.0",
    "prettier": "^3.2.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
