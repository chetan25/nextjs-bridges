# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
.next/
out/
# apps/host and apps/storefront's public/ is entirely generated: share-manifest.json
# (written by shareConfig() on next.config.ts evaluation) and *.chunk.js (tsup
# build:chunks). Run `pnpm --filter <app> build:chunks` after cloning.
apps/*/public/

# Generated shared-dep shims (generateSharedDepShim, called from tsup.config.ts
# for any shared dep other than react/react-dom) — regenerated on every build:chunks.
.bridge-shims/

# Turbo
.turbo/

# Env files
.env
.env.local
.env*.local

# Misc
.DS_Store
*.log

# SDD scratch (not needed in git history)
.superpowers/

# Planning/spec docs — working notes, not shipped documentation
docs/
